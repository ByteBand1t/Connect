// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  users           User[]
  assets          Asset[]
  documents       Document[]
  orders          Order[]
  supplierConfigs SupplierConfig[]
  activityLogs    ActivityLog[]
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  name           String
  hashedPassword String
  role           UserRole     @default(MEMBER)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  documents      Document[]
  orders         Order[]
  activityLogs   ActivityLog[]
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

model Asset {
  id                      String      @id @default(cuid())
  name                    String
  type                    AssetType
  manufacturer            String
  model                   String?
  serialNumber            String?
  location                String?
  status                  AssetStatus @default(GREEN)
  purchaseDate            DateTime?
  warrantyUntil           DateTime?
  maintenanceIntervalDays Int?
  lastMaintenanceDate     DateTime?
  nextMaintenanceDate     DateTime?
  notes                   String?
  organizationId          String
  organization            Organization @relation(fields: [organizationId], references: [id])
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  documents               Document[]
  orders                  Order[]
}

enum AssetType {
  MACHINE
  VEHICLE
  IT_EQUIPMENT
  OFFICE_EQUIPMENT
  FACILITY
  OTHER
}

enum AssetStatus {
  GREEN
  YELLOW
  RED
}

enum DocumentCategory {
  MANUAL
  SCHEMATIC
  MAINTENANCE_REPORT
  WARRANTY
  INVOICE
  CERTIFICATE
  OTHER
}

model Document {
  id             String   @id @default(cuid())
  name           String
  fileName       String
  fileSize       Int
  mimeType       String
  filePath       String
  category       DocumentCategory
  assetId        String
  asset          Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  uploadedById   String
  uploadedBy     User     @relation(fields: [uploadedById], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum OrderStatus {
  DRAFT
  SUBMITTED
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

model Order {
  id             String           @id @default(cuid())
  orderNumber    String           @unique @default(cuid())
  status         OrderStatus      @default(DRAFT)
  assetId        String
  asset          Asset            @relation(fields: [assetId], references: [id])
  items          OrderItem[]
  submissions    OrderSubmission[]
  totalAmount    Float?
  currency       String           @default("EUR")
  notes          String?
  createdById    String
  createdBy      User             @relation(fields: [createdById], references: [id])
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  partNumber  String
  name        String
  quantity    Int
  unitPrice   Float?
  totalPrice  Float?
}

model SupplierConfig {
  id             String            @id @default(cuid())
  name           String
  adapterId      String
  config         Json
  isActive       Boolean           @default(true)
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id])
  submissions    OrderSubmission[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([organizationId, name])
}

model OrderSubmission {
  id               String         @id @default(cuid())
  orderId          String
  order            Order          @relation(fields: [orderId], references: [id])
  supplierConfigId String
  supplierConfig   SupplierConfig @relation(fields: [supplierConfigId], references: [id])
  externalOrderId  String?
  status           String         @default("PENDING")
  lastStatusCheck  DateTime?
  responseData     Json?
  errorMessage     String?
  submittedAt      DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model ActivityLog {
  id              String       @id @default(cuid())
  type            String
  entityType      String
  entityId        String
  description     String
  metadata        Json?
  userId          String
  user            User         @relation(fields: [userId], references: [id])
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  createdAt       DateTime     @default(now())

  @@index([organizationId, createdAt])
}
